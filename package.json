{
  "name": "captionovo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "devDependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "docx": "^9.7.1"
  },
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "build": "npm run build --workspace=frontend",
    "start": "npm run start --workspace=frontend",
    "lint": "npm run lint --workspace=frontend",
    "dev:fe": "npm run dev --workspace=frontend",
    "dev:be": "cd backend && uv run uvicorn captionovo.main:app --reload --host 0.0.0.0 --port 4000",
    "worker": "cd backend && uv run python -m captionovo.worker",
    "configure:google-oauth": "node scripts/configure-google-oauth.mjs",
    "enable:google-oauth": "node scripts/enable-google-oauth.mjs"
  }
}
